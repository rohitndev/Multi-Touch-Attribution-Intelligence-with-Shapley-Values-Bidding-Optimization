# ---------------------------------------------------------------------------
# Multi-Touch Attribution Intelligence — environment template
# Copy to `.env` and fill in only what you need. Every value is OPTIONAL:
# when a credential is missing the pipeline runs in fully local / mock mode.
# ---------------------------------------------------------------------------

# --- Google Cloud (GA4 -> BigQuery warehouse, Pub/Sub stream) ---------------
GOOGLE_CLOUD_PROJECT=
BIGQUERY_DATASET=attribution
BIGQUERY_LOCATION=US
# Path to a service-account key OR leave blank to use Application Default Creds
GOOGLE_APPLICATION_CREDENTIALS=
PUBSUB_TOPIC=ga4-events

# --- LangChain Attribution Advisor (LLM) ------------------------------------
# Free Groq API key from https://console.groq.com  (Mixtral / Llama models)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Google Ads API ---------------------------------------------------------
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# --- Meta Marketing API -----------------------------------------------------
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_APP_ID=
META_APP_SECRET=

# --- Pipeline behaviour -----------------------------------------------------
# Set to "true" to actually push bid changes to the ad platforms.
# Default (false) keeps the agent in dry-run mode and only logs intended changes.
APPLY_BID_CHANGES=false
